@model movie_hospital_1.dataModel.Movie
@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Confirm Booking</title>

    <style>
        body {
            margin: 0;
            background: #0d0a17;
            color: white;
            font-family: Arial;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .card {
            width: 900px;
            background: #1a1625;
            padding: 30px;
            border-radius: 20px;
            display: flex;
            gap: 30px;
        }

        img {
            width: 260px;
            height: 380px;
            object-fit: cover;
            border-radius: 15px;
        }

        h2 {
            color: #d175ff;
        }

        h3 {
            color: #39ff14;
        }

        .price {
            color: gold;
            font-size: 22px;
        }

        input {
            width: 80px;
            padding: 8px;
            margin-left: 10px;
        }

        button {
            padding: 12px;
            margin-top: 15px;
            width: 100%;
            background: #d175ff;
            border: none;
            color: white;
            cursor: pointer;
            font-size: 16px;
            font-weight: bold;
            border-radius: 5px;
        }

        button:hover {
            background: #b55ed9;
        }

        .back-btn {
            background: #333;
            margin-top: 10px;
        }

        .back-btn:hover {
            background: #444;
        }
    </style>
</head>

<body>

    <div class="card">

        <img src="@Model.ImageURL" />

        <div style="flex:1">

            <h2>Confirm Booking</h2>
            <h3>@Model.Title</h3>

            <p>@Model.Description</p>

            <form id="addToCartForm">
                @Html.AntiForgeryToken()

                <input type="hidden" name="movieId" value="@Model.Id" />

                <label>Tickets:</label>
                <input type="number" id="qty" name="quantity" value="1" min="1" />

                <h3 class="price">
                    Total: $<span id="total">0.00</span>
                </h3>

                <button type="submit">Add To Cart</button>
            </form>

            <a href="/Home/Index">
                <button type="button" class="back-btn">Back</button>
            </a>

        </div>

    </div>

    <script>
        let price = parseFloat("@Model.Price");
        let qty = document.getElementById("qty");
        let totalSpan = document.getElementById("total");

        function calc() {
            let q = parseInt(qty.value) || 1;
            if (q < 1) qty.value = 1;
            totalSpan.innerText = (price * q).toFixed(2);
        }

        qty.addEventListener("input", calc);
        calc();

        const form = document.getElementById("addToCartForm");

        form.addEventListener("submit", async function(e) {
            e.preventDefault();

            const formData = new FormData(form);

            try {
                const response = await fetch('/Orders/AddToCart', {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    }
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    window.location.href = '/Orders/Cart';
                } else {
                    alert(result.message);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('An error occurred. Please try again.');
            }
        });
    </script>

</body>
</html>