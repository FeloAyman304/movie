@model movie_hospital_1.dataModel.Movie

@{
    Layout = null;
    ViewData["Title"] = "Confirm Booking";
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Confirm Booking</title>

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
        }

        .neon-heading {
            color: #d175ff;
            text-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            text-align: center;
            margin-top: 30px;
        }

        .booking-card {
            background-color: #1a1625;
            border: 2px solid #6a0dad;
            box-shadow: 0 0 20px rgba(106, 13, 173, 0.5);
            border-radius: 15px;
            padding: 20px;
        }

        .booking-image {
            max-height: 250px;
            border: 3px solid #d175ff;
            border-radius: 10px;
        }

        .neon-title {
            color: #39ff14;
            text-shadow: 0 0 8px rgba(57, 255, 20, 0.8);
        }

        .price-value {
            color: #ffcc00;
            font-weight: bold;
        }

        .quantity-input {
            background-color: #0d0a17;
            border: 1px solid #6a0dad;
            color: white;
        }

        .neon-submit-btn {
            background-color: #d175ff;
            border: none;
            color: #1a1625;
            font-weight: bold;
            padding: 10px;
            border-radius: 8px;
            width: 100%;
        }

            .neon-submit-btn:hover {
                background-color: #e599ff;
            }

        #totalPriceDisplay {
            color: #ffcc00;
            font-weight: bold;
        }

        dl dt {
            color: #d175ff;
        }

        dl dd, p {
            color: white;
        }
    </style>
</head>

<body>

    <h2 class="neon-heading">🎟️ Confirm Your Booking</h2>

    <div class="container" style="max-width:900px; margin:auto; margin-top:30px;">
        <div class="booking-card">

            <div style="display:flex; gap:20px;">

                <div style="width:30%; text-align:center;">
                    @if (!string.IsNullOrEmpty(Model.ImageURL))
                    {
                        <img src="@Model.ImageURL" class="booking-image" />
                    }
                    else
                    {
                        <div>No Image Available</div>
                    }
                </div>

                <div style="width:70%;">

                    <h3 class="neon-title">@Model.Title</h3>
                    <p>@Model.Description</p>

                    <hr />

                    <dl>
                        <dt>Category:</dt>
                        <dd>@Model.Category?.Name</dd>

                        <dt>Cinema:</dt>
                        <dd>@Model.Cinema?.Name</dd>

                        <dt>Price:</dt>
                        <dd class="price-value">@Model.Price.ToString("C")</dd>
                    </dl>

                    <hr />

                    <form asp-action="Book" asp-controller="Orders" method="post">
                        <input type="hidden" name="movieId" value="@Model.Id" />

                        <div style="margin-bottom:15px;">
                            <label>Tickets:</label>
                            <input type="number" id="quantity" name="quantity"
                                   value="1" min="1" class="quantity-input" />
                        </div>

                        <h4>Total: <span id="totalPriceDisplay"></span></h4>

                        <button type="submit" class="neon-submit-btn">
                            Confirm and Pay
                        </button>
                    </form>

                </div>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const price = @Model.Price;
            const qty = document.getElementById("quantity");
            const total = document.getElementById("totalPriceDisplay");

            function update() {
                const q = parseInt(qty.value) || 1;
                total.textContent = (price * q).toLocaleString('en-US', {
                    style: 'currency',
                    currency: 'USD'
                });
            }

            qty.addEventListener("input", update);
            update();
        });
    </script>

</body>
</html>