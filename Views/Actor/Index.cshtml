@{
    Layout = null;
}

@model IEnumerable<movie_hospital_1.dataModel.Actor>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Actors List</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        .top-bar {
            max-width: 1000px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .btn-primary {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
        }

            .btn-primary:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
            color: #f0f0f0;
            font-weight: bold;
            transition: 0.3s;
            border-radius: 8px;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
                box-shadow: 0 0 12px rgba(209, 117, 255, 0.6);
                transform: translateY(-2px);
            }

        .search-box {
            width: 250px;
            border-radius: 8px;
            padding: 6px;
            border: 1px solid #6a0dad;
            background-color: #1a1625;
            color: white;
        }

        table {
            width: 100%;
            max-width: 1000px;
            margin: auto;
            background-color: #1a1625;
            border-radius: 10px;
            overflow: hidden;
        }

        thead {
            background-color: #3b3054;
        }

        th {
            color: #d175ff;
            padding: 10px;
        }

        td {
            padding: 10px;
            border-top: 1px solid #3b3054;
            vertical-align: middle;
        }

        tr:hover {
            background-color: #2b263b;
        }

        img {
            width: 70px;
            height: 70px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #d175ff;
        }

        .btn-warning {
            background-color: #d175ff;
            border: none;
            color: #1a1625;
            font-weight: bold;
        }

        .btn-danger {
            background-color: #ff4d4d;
            border: none;
        }

            .btn-warning:hover,
            .btn-danger:hover {
                transform: scale(1.05);
            }
    </style>
</head>

<body>

    <h2> Actors List</h2>

    <div class="top-bar">

        <div>
            <a asp-action="Create" class="btn btn-primary">Add Actor</a>

            <a href="/Admin/Dashboard" class="btn btn-secondary ms-2">
                 Back to Dashboard
            </a>
        </div>

        <input type="text" id="search" class="search-box" placeholder="Search actor..." />

    </div>

    <table id="actorsTable">

        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Bio</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var actor in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(actor.ProfilePicture))
                        {
                            <img src="@actor.ProfilePicture" />
                        }
                        else
                        {
                            <span>No Image</span>
                        }
                    </td>

                    <td class="name">@actor.Name</td>
                    <td>@actor.Bio</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@actor.Id"
                           class="btn btn-warning btn-sm">Edit</a>

                        <a asp-action="Delete" asp-route-id="@actor.Id"
                           class="btn btn-danger btn-sm delete-btn">Delete</a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const search = document.getElementById("search");
            const rows = document.querySelectorAll("#actorsTable tbody tr");

            search.addEventListener("input", function () {
                const value = this.value.toLowerCase();

                rows.forEach(row => {
                    const name = row.querySelector(".name").textContent.toLowerCase();
                    row.style.display = name.includes(value) ? "" : "none";
                });
            });

            const deletes = document.querySelectorAll(".delete-btn");

            deletes.forEach(btn => {
                btn.addEventListener("click", function (e) {
                    const ok = confirm("Are you sure you want to delete this actor?");
                    if (!ok) {
                        e.preventDefault();
                    }
                });
            });

        });
    </script>

</body>
</html>