@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Actor

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Add Actor</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 25px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        form {
            max-width: 520px;
            margin: auto;
            background-color: #1a1625;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #6a0dad;
            box-shadow: 0 0 20px rgba(106, 13, 173, 0.6);
        }

        label {
            color: #d175ff;
            font-weight: bold;
        }

        .form-control {
            background-color: #2b263b;
            border: 1px solid #6a0dad;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus {
                border-color: #d175ff;
                box-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
                background-color: #3a3350;
                color: white;
            }

        .btn-primary {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
        }

            .btn-primary:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
            }
    </style>
</head>

<body>

    <h2>➕ Add New Actor</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="actorForm">

        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Name" class="form-control" id="name" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Bio</label>
            <textarea asp-for="Bio" class="form-control" id="bio"></textarea>
        </div>

        <div class="mb-3">
            <label>Profile Picture</label>
            <input type="file" name="ProfileImage" class="form-control" id="image" accept="image/*" />
        </div>

        <button type="submit" class="btn btn-primary w-100 mb-2" id="saveBtn">
            Save Actor
        </button>

        <a asp-action="Index" class="btn btn-secondary w-100">
            Back
        </a>

    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("actorForm");
            const name = document.getElementById("name");
            const saveBtn = document.getElementById("saveBtn");

            name.addEventListener("input", function () {
                if (name.value.length > 0) {
                    name.style.borderColor = "#d175ff";
                } else {
                    name.style.borderColor = "#6a0dad";
                }
            });

            form.addEventListener("submit", function (e) {

                if (name.value.trim() === "") {
                    alert("Actor name is required!");
                    e.preventDefault();
                    return;
                }

                const confirmSave = confirm("Are you sure you want to add this actor?");
                if (!confirmSave) {
                    e.preventDefault();
                }
            });

        });
    </script>

</body>
</html>