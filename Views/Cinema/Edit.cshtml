@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Cinema

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Edit Cinema</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 25px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        form {
            max-width: 520px;
            margin: auto;
            background-color: #1a1625;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #6a0dad;
            box-shadow: 0 0 20px rgba(106, 13, 173, 0.6);
        }

        label {
            color: #d175ff;
            font-weight: bold;
        }

        .form-control {
            background-color: #2b263b;
            border: 1px solid #6a0dad;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus {
                background-color: #3a3350;
                border-color: #d175ff;
                box-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
                color: white;
            }

        .btn-primary {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
        }

            .btn-primary:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
            }

        .preview-img {
            width: 150px;
            height: 100px;
            object-fit: cover;
            border-radius: 8px;
            border: 3px solid #d175ff;
            margin-bottom: 10px;
        }

        .text-muted {
            color: #9333ea !important;
        }
    </style>
</head>

<body>

    <h2>✏️ Edit Cinema</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data" id="cinemaForm">

        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label>Name</label>
            <input asp-for="Name" class="form-control" id="name" />
        </div>

        <div class="mb-3">
            <label>Location</label>
            <input asp-for="Location" class="form-control" id="location" />
        </div>

        <div class="mb-3">
            <label>Current Image</label><br />

            @if (!string.IsNullOrEmpty(Model.ImageURL))
            {
                <img src="@Model.ImageURL" class="preview-img" id="currentImg" />
            }
            else
            {
                <p class="text-muted">No image uploaded</p>
            }
        </div>

        <div class="mb-3">
            <label>Upload New Image</label>
            <input type="file" name="ImageFile" class="form-control" id="imageInput" accept="image/*" />
        </div>

        <div class="d-flex justify-content-between">

            <a asp-action="Index" class="btn btn-secondary px-4">
                ⬅ Back
            </a>

            <button type="submit" class="btn btn-primary px-4">
                💾 Update
            </button>

        </div>

    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("cinemaForm");
            const name = document.getElementById("name");
            const location = document.getElementById("location");
            const imageInput = document.getElementById("imageInput");

            function validate(field) {
                field.style.borderColor = field.value.trim() === "" ? "red" : "#d175ff";
            }

            name.addEventListener("input", () => validate(name));
            location.addEventListener("input", () => validate(location));

            // preview new image
            imageInput.addEventListener("change", function () {
                const file = this.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = function (e) {
                        let img = document.getElementById("currentImg");

                        if (!img) {
                            img = document.createElement("img");
                            img.className = "preview-img";
                            imageInput.parentNode.insertBefore(img, imageInput);
                        }

                        img.src = e.target.result;
                    };
                    reader.readAsDataURL(file);
                }
            });

            form.addEventListener("submit", function (e) {

                if (name.value.trim() === "" || location.value.trim() === "") {
                    alert("Please fill all required fields!");
                    e.preventDefault();
                    return;
                }

                const ok = confirm("Are you sure you want to update this cinema?");
                if (!ok) {
                    e.preventDefault();
                }
            });

        });
    </script>

</body>
</html>