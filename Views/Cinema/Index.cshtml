@{
    Layout = null;
    ViewData["Title"] = "Cinema List";
}

@model IEnumerable<movie_hospital_1.dataModel.Cinema>

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Cinema List</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        .top-bar {
            max-width: 1000px;
            margin: auto;
            display: flex;
            justify-content: space-between;
            margin-bottom: 15px;
        }

        .btn-success {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
        }

            .btn-success:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
            color: #f0f0f0;
            font-weight: bold;
            border-radius: 8px;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
                box-shadow: 0 0 12px rgba(209, 117, 255, 0.6);
            }

        table {
            width: 100%;
            max-width: 1000px;
            margin: auto;
            background-color: #1a1625;
            border-radius: 10px;
            overflow: hidden;
        }

        thead {
            background-color: #3b3054;
        }

        th {
            color: #d175ff;
            padding: 10px;
            text-transform: uppercase;
        }

        td {
            padding: 10px;
            border-top: 1px solid #3b3054;
            vertical-align: middle;
        }

        tr:hover {
            background-color: #2b263b;
        }

        .imgCinema {
            width: 80px;
            height: 60px;
            object-fit: cover;
            border-radius: 8px;
            border: 2px solid #6a0dad;
        }

        .btn-warning {
            background-color: #d175ff;
            border: none;
            color: #1a1625;
            font-weight: bold;
        }

        .btn-danger {
            background-color: #ff4d4d;
            border: none;
        }

            .btn-warning:hover,
            .btn-danger:hover {
                transform: scale(1.05);
            }

        .text-muted {
            color: #9333ea !important;
        }
    </style>
</head>

<body>

    <h2> Cinema List</h2>

    <div class="top-bar">

        <div>
            <a asp-action="Create" class="btn btn-success">
                Add New Cinema
            </a>
        </div>

        <a href="/Admin/Dashboard" class="btn btn-secondary">
             Dashboard
        </a>

    </div>

    <table>

        <thead>
            <tr>
                <th>Image</th>
                <th>Name</th>
                <th>Location</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageURL))
                        {
                            <img src="@item.ImageURL" class="imgCinema" />
                        }
                        else
                        {
                            <span class="text-muted">No Image</span>
                        }
                    </td>

                    <td>@item.Name</td>
                    <td>@item.Location</td>

                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                             Edit
                        </a>

                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                             Delete
                        </a>
                    </td>
                </tr>
            }
        </tbody>

    </table>

</body>
</html>