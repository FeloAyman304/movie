@model movie_hospital_1.dataModel.Movie
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Edit Movie - Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial, sans-serif;
            padding: 40px 20px;
        }

        h2 {
            text-align: center;
            color: #d175ff;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
            margin-bottom: 30px;
            font-weight: bold;
        }

        form {
            max-width: 700px;
            margin: auto;
            padding: 30px;
            background: #1a1625;
            border: 2px solid #6a0dad;
            border-radius: 15px;
            box-shadow: 0 0 25px rgba(106, 13, 173, 0.4);
        }

        .form-label {
            color: #d175ff;
            font-weight: bold;
            margin-top: 10px;
        }

        .form-control, .form-select {
            background: #2b263b;
            border: 1px solid #6a0dad;
            color: white !important;
            border-radius: 8px;
            padding: 10px;
        }

            .form-control:focus, .form-select:focus {
                border-color: #d175ff;
                box-shadow: 0 0 12px rgba(209, 117, 255, 0.6);
                background: #3f3952;
            }

        .poster-preview {
            border-radius: 10px;
            border: 2px solid #d175ff;
            box-shadow: 0 0 15px rgba(209, 117, 255, 0.3);
            width: 120px;
            margin-top: 10px;
            transition: 0.3s;
        }

        .btn-save {
            background: #6a0dad;
            border: none;
            color: white;
            font-weight: bold;
            padding: 10px 25px;
            border-radius: 8px;
            transition: 0.3s;
        }

            .btn-save:hover {
                background: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
                transform: translateY(-2px);
            }

        .btn-back {
            background: transparent;
            border: 1px solid #fff;
            color: white;
            padding: 10px 25px;
            border-radius: 8px;
            text-decoration: none;
            transition: 0.3s;
            display: inline-block;
        }

            .btn-back:hover {
                background: rgba(255,255,255,0.1);
                color: #d175ff;
            }

        .text-danger {
            font-size: 0.85rem;
            margin-top: 5px;
            display: block;
        }

        .form-check-input:checked {
            background-color: #6a0dad;
            border-color: #d175ff;
        }
    </style>
</head>

<body>

    <h2>✏️ Edit Movie Details</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="row">
            <div class="col-md-12 mb-3">
                <label asp-for="Title" class="form-label">Movie Title</label>
                <input asp-for="Title" class="form-control" placeholder="Enter movie title" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="col-md-12 mb-3">
                <label asp-for="Description" class="form-label">Description</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Current Poster</label><br />
                @if (!string.IsNullOrEmpty(Model.ImageURL))
                {
                    <img src="@Model.ImageURL" class="poster-preview" alt="Current Poster" />
                }
                else
                {
                    <p class="text-muted small">No poster available</p>
                }
            </div>

            <div class="col-md-6 mb-3">
                <label class="form-label">Upload New Poster</label>
                <input type="file" name="ImageFile" class="form-control" />
                <small class="text-muted d-block mt-1">Leave empty to keep current image</small>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-select"
                        asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                    <option value="">-- Choose Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="CinemaId" class="form-label">Cinema</label>
                <select asp-for="CinemaId" class="form-select"
                        asp-items="@(new SelectList(ViewBag.Cinemas, "Id", "Name"))">
                    <option value="">-- Choose Cinema --</option>
                </select>
                <span asp-validation-for="CinemaId" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3">
                <label asp-for="Price" class="form-label">Ticket Price</label>
                <div class="input-group">
                    <span class="input-group-text bg-dark text-white border-secondary">$</span>
                    <input asp-for="Price" class="form-control" />
                </div>
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="col-md-6 mb-3 d-flex align-items-end pb-2">
                <div class="form-check">
                    <input asp-for="InCinema" class="form-check-input" type="checkbox" id="statusCheck" />
                    <label class="form-check-label text-white ms-2" for="statusCheck">
                        Currently in Cinema (Active)
                    </label>
                </div>
            </div>

            <div class="col-md-12 mb-4">
                <label class="form-label">Assign Actors</label>
                <select name="selectedActors" class="form-select" multiple size="5" style="height: 120px;">
                    @foreach (var actor in ViewBag.Actors as List<movie_hospital_1.dataModel.Actor>)
                    {
                        var isSelected = Model.MovieActors?.Any(ma => ma.ActorId == actor.Id) ?? false;
                        <option value="@actor.Id" selected="@(isSelected ? "selected" : null)">
                            @actor.Name
                        </option>
                    }
                </select>
                <small class="text-muted">Hold Ctrl to select multiple actors</small>
            </div>
        </div>

        <hr style="border-color: #6a0dad; margin-bottom: 25px;">

        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn-back"> Back to List</a>
            <button type="submit" class="btn btn-save"> Save Changes</button>
        </div>
    </form>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.3/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>

</body>
</html>