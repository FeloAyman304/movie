@model movie_hospital_1.dataModel.Movie
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Edit Movie</title>

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            text-align: center;
            color: #d175ff;
            text-shadow: 0 0 10px rgba(209,117,255,0.8);
            margin-bottom: 20px;
        }

        form {
            max-width: 650px;
            margin: auto;
            padding: 25px;
            background: #1a1625;
            border: 1px solid #6a0dad;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(106,13,173,0.6);
        }

        .form-label {
            color: #d175ff;
            font-weight: bold;
        }

        .form-control, .form-select {
            background: #2b263b;
            border: 1px solid #6a0dad;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus, .form-select:focus {
                border-color: #d175ff;
                box-shadow: 0 0 10px rgba(209,117,255,0.8);
                background: #3f3952;
                color: white;
            }

        img {
            border-radius: 8px;
            border: 3px solid #d175ff;
            box-shadow: 0 0 10px rgba(209,117,255,0.5);
            width: 150px;
        }

        .btn-success {
            background: #6a0dad;
            border: none;
            margin-right: 10px;
        }

            .btn-success:hover {
                background: #9333ea;
                box-shadow: 0 0 15px rgba(209,117,255,0.8);
            }

        .btn-secondary {
            background: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background: #4c406b;
            }

        .text-danger {
            color: #ff6666 !important;
        }
    </style>
</head>

<body>

    <h2>✏ Edit Movie</h2>

    <form asp-action="Edit" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Title</label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label class="form-label">Current Poster</label><br />
            @if (!string.IsNullOrEmpty(Model.ImageURL))
            {
                <img src="@Model.ImageURL" />
            }
            else
            {
                <p>No image uploaded</p>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">New Poster</label>
            <input type="file" name="ImageFile" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Category</label>
            <select asp-for="CategoryId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name", Model.CategoryId))">
                <option value="">Select Category</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Cinema</label>
            <select asp-for="CinemaId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Cinemas, "Id", "Name", Model.CinemaId))">
                <option value="">Select Cinema</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Price</label>
            <input asp-for="Price" class="form-control" />
        </div>

        <div class="mb-3">
            <label class="form-label">Actors</label>
            <select name="selectedActors" class="form-select" multiple size="5">
                @foreach (var actor in ViewBag.Actors as List<movie_hospital_1.dataModel.Actor>)
                {
                    var isSelected = Model.MovieActors?.Any(ma => ma.ActorId == actor.Id) ?? false;
                    <option value="@actor.Id" selected="@(isSelected ? "selected" : null)">
                        @actor.Name
                    </option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Status</label>
            <div>
                <input asp-for="InCinema" type="checkbox" />
                <label>Active</label>
            </div>
        </div>

        <button type="submit" class="btn btn-success">💾 Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary">⬅ Back</a>
    </form>

</body>
</html>