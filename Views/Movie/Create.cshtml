@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Movie
@using Microsoft.AspNetCore.Mvc.Rendering

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Add Movie</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 25px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        form {
            max-width: 650px;
            margin: auto;
            background-color: #1a1625;
            padding: 25px;
            border-radius: 12px;
            border: 1px solid #6a0dad;
            box-shadow: 0 0 20px rgba(106, 13, 173, 0.6);
        }

        label {
            color: #d175ff;
            font-weight: bold;
        }

        .form-control, .form-select {
            background-color: #2b263b;
            border: 1px solid #6a0dad;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus, .form-select:focus {
                background-color: #3a3350;
                border-color: #d175ff;
                box-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
                color: white;
            }

        small.text-muted {
            color: #9333ea !important;
        }

        .btn-success {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
        }

            .btn-success:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
            }

        .error {
            color: #ff4d4d;
            font-size: 0.9rem;
        }
    </style>
</head>

<body>

    <h2> Add New Movie</h2>

    <form asp-action="Create" method="post" enctype="multipart/form-data" id="movieForm">

        <div class="mb-3">
            <label>Title</label>
            <input asp-for="Title" class="form-control" id="title" />
            <span asp-validation-for="Title" class="error"></span>
        </div>

        <div class="mb-3">
            <label>Description</label>
            <textarea asp-for="Description" class="form-control" id="desc"></textarea>
            <span asp-validation-for="Description" class="error"></span>
        </div>

        <div class="mb-3">
            <label>Poster Image</label>
            <input type="file" name="ImageFile" class="form-control" />
            <small class="text-muted">Upload movie poster</small>
        </div>

        <div class="mb-3">
            <label>Category</label>
            <select asp-for="CategoryId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Categories, "Id", "Name"))">
                <option value="">-- Select Category --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Cinema</label>
            <select asp-for="CinemaId" class="form-select"
                    asp-items="@(new SelectList(ViewBag.Cinemas, "Id", "Name"))">
                <option value="">-- Select Cinema --</option>
            </select>
        </div>

        <div class="mb-3">
            <label>Price</label>
            <input asp-for="Price" class="form-control" id="price" />
        </div>

        <div class="mb-3">
            <label>Actors</label>
            <select name="selectedActors" class="form-select" multiple size="5"
                    id="actorsSelect"
                    asp-items="@(new SelectList(ViewBag.Actors, "Id", "Name"))">
            </select>
        </div>

        <div class="mb-3 form-check">
            <input asp-for="InCinema" class="form-check-input" type="checkbox" />
            <label class="form-check-label">Active (In Cinema)</label>
        </div>

        <div class="d-flex justify-content-between">

            <a asp-action="Index" class="btn btn-secondary px-4">
                 Back
            </a>

            <button type="submit" class="btn btn-success px-4">
                 Save Movie
            </button>

        </div>

    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("movieForm");
            const title = document.getElementById("title");
            const price = document.getElementById("price");

            function validate(field) {
                field.style.borderColor = field.value.trim() === "" ? "red" : "#d175ff";
            }

            title.addEventListener("input", () => validate(title));
            price.addEventListener("input", () => validate(price));

            form.addEventListener("submit", function (e) {

                if (title.value.trim() === "" || price.value.trim() === "") {
                    alert("Please fill required fields!");
                    e.preventDefault();
                    return;
                }

                const ok = confirm("Are you sure you want to add this movie?");
                if (!ok) {
                    e.preventDefault();
                }
            });

        });
    </script>

</body>
</html>