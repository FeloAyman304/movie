@model IEnumerable<movie_hospital_1.dataModel.Movie>

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Movies List - Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />

    <style>
        body {
            background-color: #0d0a17; 
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.5);
            font-weight: bold;
        }

        .custom-dark-table {
            background-color: #000000 !important; 
            color: #ffffff !important;
            border: 1px solid #3b3054;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.5);
        }

            .custom-dark-table thead {
                background-color: #1a1625; /
                color: #d175ff;
            }

            .custom-dark-table th {
                border-bottom: 2px solid #3b3054 !important;
                padding: 15px;
                text-transform: uppercase;
                font-size: 0.9rem;
                letter-spacing: 1px;
            }

            .custom-dark-table td {
                border: 1px solid #1a1625 !important;
                padding: 12px;
                vertical-align: middle;
                color: black !important; 
            }

            .custom-dark-table tbody tr:hover {
                background-color: #0a0a0a !important;
                transition: 0.3s;
            }

        .price-cell {
            color: #ffcc00 !important; 
            font-weight: bold;
            font-size: 1.1rem;
        }

        .btn-primary {
            background-color: #6a0dad;
            border: none;
        }

            .btn-primary:hover {
                background-color: #8a2be2;
            }
    </style>
</head>
<body>

    <div class="container-fluid mt-4">
        <h2 class="text-center mb-4">🎬 Movies List</h2>

        <div class="d-flex justify-content-between mb-4">
            <a asp-action="Create" class="btn btn-primary px-4 shadow">➕ Add Movie</a>
            <a href="/Admin/Dashboard" class="btn btn-outline-light">⬅ Back to Dashboard</a>
        </div>

        <div class="table-responsive">
            <table class="table custom-dark-table">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Cinema</th>
                        <th>Image</th>
                        <th>Actors</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Title</td>
                                <td>@item.Category?.Name</td>
                                <td>@item.Cinema?.Name</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.ImageURL))
                                    {
                                        <img src="@item.ImageURL" width="60" height="85" style="object-fit: cover;" class="rounded border border-secondary shadow-sm" />
                                    }
                                    else
                                    {
                                        <small class="text-muted">No Image</small>
                                    }
                                </td>
                                <td>
                                    @if (item.MovieActors != null)
                                    {
                                        foreach (var ma in item.MovieActors)
                                        {
                                            <span class="badge bg-dark border border-secondary mb-1">@ma.Actor?.Name</span>
                            
                                            <br />
                                        }
                                    }
                                </td>
                                <td class="price-cell">@item.Price.ToString("C")</td>
                                <td>
                                    @if (item.InCinema)
                                    {
                                        <span class="badge bg-success shadow-sm">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger shadow-sm">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center py-5 text-muted">No movies available in the hospital list.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>