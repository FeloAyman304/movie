@model IEnumerable<movie_hospital_1.dataModel.Movie>

@{
    Layout = null;
}

<div class="container-fluid mt-4">
    <h2 class="text-center">🎬 Movies List</h2>

    <div class="d-flex justify-content-between mb-3">
        <a asp-action="Create" class="btn btn-primary">➕ Add Movie</a>

        <!-- 🔙 زرار الرجوع للـ Dashboard -->
        <a href="/Admin/Dashboard" class="btn btn-outline-light">
            ⬅ Back to Dashboard
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    <th>Cinema</th>
                    <th>Image</th>
                    <th>Actors</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Title</td>
                        <td>@item.Category?.Name</td>
                        <td>@item.Cinema?.Name</td>

                        <td>
                            @if (!string.IsNullOrEmpty(item.ImageURL))
                            {
                                <img src="@item.ImageURL" width="80" class="rounded shadow-sm" />
                            }
                            else
                            {
                                <span class="text-muted">No Image</span>
                            }
                        </td>

                        <td>
                            @if (item.MovieActors != null && item.MovieActors.Any())
                            {
                                @foreach (var ma in item.MovieActors)
                                {
                                    @ma.Actor?.Name <br />
                                }
                            }
                            else
                            {
                                <span class="text-muted">No Actors</span>
                            }
                        </td>

                        <td class="price-cell">
                            @item.Price.ToString("C")
                        </td>

                        <td>
                            @if (item.InCinema)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Not Active</span>
                            }
                        </td>

                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">✏ Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">🗑 Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    body {
        background-color: #0d0a17;
        color: #f0f0f0;
        font-family: Arial;
        padding: 20px;
    }

    h2 {
        color: #d175ff;
        text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
    }

    .btn-primary {
        background-color: #6a0dad;
        border: none;
        font-weight: bold;
    }

    .btn-outline-light {
        border: 1px solid #fff;
        color: #fff;
    }

    .table {
        background-color: #1a1625;
        color: white;
    }

    .table thead {
        background-color: #3b3054;
    }

    .price-cell {
        color: gold;
        font-weight: bold;
    }

    .btn-warning {
        background-color: #d175ff;
        border: none;
        color: #1a1625;
    }

    .btn-danger {
        background-color: #ff4d4d;
        border: none;
    }
</style>