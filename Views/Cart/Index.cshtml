@model IEnumerable<movie_hospital_1.dataModel.Order>

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>My Cart</title>

    <style>
        body {
            margin: 0;
            background: #0d0a17;
            color: white;
            font-family: Arial;
            padding: 40px;
        }

        h1 {
            text-align: center;
            color: #d175ff;
            margin-bottom: 30px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            background: #1a1625;
            border-radius: 15px;
            overflow: hidden;
        }

        th, td {
            padding: 15px;
            text-align: center;
        }

        th {
            background: #d175ff;
        }

        tr {
            border-bottom: 1px solid #333;
        }

        img {
            width: 70px;
            height: 100px;
            object-fit: cover;
            border-radius: 10px;
        }

        .price {
            color: gold;
            font-weight: bold;
        }

        .empty {
            text-align: center;
            margin-top: 50px;
            font-size: 25px;
            color: gray;
        }
    </style>
</head>
<body>

    <h1>🛒 My Cart</h1>

    @if (Model.Any())
    {
        <table>
            <tr>
                <th>Image</th>
                <th>Movie</th>
                <th>Tickets</th>
                <th>Total</th>
                <th>Date</th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>
                        <img src="@item.Movie.ImageURL" />
                    </td>

                    <td>@item.Movie.Title</td>

                    <td>@item.Quantity</td>

                    <td class="price">@item.TotalPrice.ToString("C")</td>

                    <td>@item.OrderDate.ToShortDateString()</td>
                </tr>
            }
        </table>
    }
    else
    {
        <div class="empty">Cart Is Empty</div>
    }

</body>
</html>