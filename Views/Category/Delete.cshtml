@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Category

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Delete Category</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
        }

        .container {
            max-width: 600px;
            margin-top: 80px;
        }

        .card {
            background-color: #1a1625;
            border: 1px solid #ff4d4d;
            box-shadow: 0 0 20px rgba(255, 77, 77, 0.4);
            border-radius: 12px;
            padding: 25px;
        }

        h2 {
            color: #ff4d4d;
            text-align: center;
            text-shadow: 0 0 10px rgba(255, 77, 77, 0.6);
        }

        h5 {
            text-align: center;
            color: #f0f0f0;
            margin-bottom: 25px;
        }

        label {
            color: #d175ff;
            font-weight: bold;
        }

        p {
            background-color: #2b263b;
            padding: 10px;
            border-radius: 8px;
            border: 1px solid #3b3054;
            color: white;
        }

        .btn-danger {
            background-color: #ff4d4d;
            border: none;
            font-weight: bold;
        }

            .btn-danger:hover {
                box-shadow: 0 0 15px rgba(255, 77, 77, 0.8);
                transform: scale(1.05);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
            }
    </style>
</head>

<body>

    <div class="container">

        <div class="card">

            <h2>🗑 Delete Category</h2>

            <h5>Are you sure you want to delete this category?</h5>

            <form asp-action="DeleteConfirmed" method="post" id="deleteForm">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label>Category Name</label>
                    <p>@Model.Name</p>
                </div>

                <div class="mb-3">
                    <label>Description</label>
                    <p>@Model.Description</p>
                </div>

                <div class="d-flex justify-content-between mt-4">

                    <a asp-action="Index" class="btn btn-secondary px-4">
                        ⬅ Cancel
                    </a>

                    <button type="submit" class="btn btn-danger px-4" id="deleteBtn">
                        🗑 Confirm Delete
                    </button>

                </div>

            </form>

        </div>

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("deleteForm");

            form.addEventListener("submit", function (e) {

                const ok = confirm("⚠ Are you REALLY sure you want to delete this category?");

                if (!ok) {
                    e.preventDefault();
                }
            });

        });
    </script>

</body>
</html>