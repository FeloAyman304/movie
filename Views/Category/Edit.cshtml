@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Category

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Edit Category</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
            padding: 20px;
        }

        .container {
            max-width: 600px;
            margin-top: 60px;
        }

        .card {
            background-color: #1a1625;
            border: 1px solid #6a0dad;
            border-radius: 12px;
            box-shadow: 0 0 20px rgba(106, 13, 173, 0.6);
            padding: 25px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 20px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        label {
            color: #d175ff;
            font-weight: bold;
        }

        .form-control {
            background-color: #2b263b;
            border: 1px solid #6a0dad;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus {
                background-color: #3a3350;
                border-color: #d175ff;
                box-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
                color: white;
            }

        .btn-success {
            background-color: #6a0dad;
            border: none;
            font-weight: bold;
            transition: 0.3s;
        }

            .btn-success:hover {
                background-color: #9333ea;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
            }

        .btn-secondary {
            background-color: #3b3054;
            border: none;
        }

            .btn-secondary:hover {
                background-color: #4c406b;
            }
    </style>
</head>

<body>

    <div class="container">

        <div class="card">

            <h2>✏ Edit Category</h2>

            <form asp-action="Edit" method="post" id="editForm">

                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label>Name</label>
                    <input asp-for="Name" class="form-control" id="name" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label>Description</label>
                    <textarea asp-for="Description" class="form-control" id="desc"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between mt-4">

                    <a asp-action="Index" class="btn btn-secondary px-4">
                         Back
                    </a>

                    <button type="submit" class="btn btn-success px-4">
                         Save
                    </button>

                </div>

            </form>

        </div>

    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const form = document.getElementById("editForm");
            const name = document.getElementById("name");

            name.addEventListener("input", function () {
                name.style.borderColor = name.value.trim() === "" ? "red" : "#d175ff";
            });

            form.addEventListener("submit", function (e) {

                if (name.value.trim() === "") {
                    alert("Category name is required!");
                    e.preventDefault();
                    return;
                }

                const ok = confirm("Are you sure you want to update this category?");
                if (!ok) {
                    e.preventDefault();
                }
            });

        });
    </script>

</body>
</html>