@{
    Layout = null;
    ViewData["Title"] = "Dashboard";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Admin Dashboard</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial, sans-serif;
            padding: 20px;
        }

        h2 {
            color: #d175ff;
            text-align: center;
            margin-bottom: 40px;
            text-shadow: 0 0 10px rgba(209, 117, 255, 0.8);
        }

        ul {
            list-style: none;
            padding: 0;
            max-width: 500px;
            margin: auto;
        }

        .nav-item {
            margin-bottom: 18px;
        }

        .nav-link {
            display: block;
            padding: 18px;
            text-align: center;
            text-decoration: none;
            color: white;
            background-color: #1a1625;
            border: 2px solid #6a0dad;
            border-radius: 12px;
            transition: 0.3s;
            font-weight: bold;
        }

            .nav-link:hover {
                background-color: #2b263b;
                color: #d175ff;
                box-shadow: 0 0 15px rgba(209, 117, 255, 0.8);
                transform: translateY(-3px);
            }

        .logout-btn {
            position: absolute;
            top: 20px;
            right: 20px;
        }

        .btn-danger-neon {
            background-color: #ff4d4d;
            border: none;
            color: white;
            padding: 8px 14px;
            border-radius: 8px;
            font-weight: bold;
            text-decoration: none;
            transition: 0.3s;
        }

            .btn-danger-neon:hover {
                box-shadow: 0 0 15px rgba(255, 77, 77, 0.8);
                transform: scale(1.05);
                color: white;
            }
    </style>
</head>

<body>

    <div class="logout-btn">
        <a href="/Account/Logout" class="btn-danger-neon">Logout</a>
    </div>

    <h2>Welcome to Admin Dashboard</h2>

    <ul>
        <li class="nav-item">
            <a class="nav-link" href="/Category/Index">Category Management</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="/Cinema/Index">Cinema Management</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="/Actor/Index">Actor Management</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="/Movie/Index">Movie Management</a>
        </li>

        <li class="nav-item">
            <a class="nav-link" href="/" style="border-color: #00d4ff; color: #00d4ff;">
                View Website 
            </a>
        </li>
    </ul>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const links = document.querySelectorAll(".nav-link");

            links.forEach(link => {
                link.addEventListener("mouseenter", () => {
                    link.style.letterSpacing = "2px";
                });

                link.addEventListener("mouseleave", () => {
                    link.style.letterSpacing = "normal";
                });
            });
        });
    </script>

</body>
</html>