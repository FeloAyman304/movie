@{
    Layout = null;
}

@model movie_hospital_1.dataModel.Movie

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Movie Details</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">

    <style>
        body {
            background-color: #0b0a12;
            color: #f5f5f5;
            font-family: Arial;
        }

        .card {
            background-color: #151223;
            border: 1px solid #2e2447;
            border-radius: 16px;
            box-shadow: 0 0 20px rgba(168, 85, 247, 0.15);
            max-width: 1000px;
            margin: 40px auto;
        }

        h2 {
            color: #c084fc;
            font-weight: bold;
        }

        h5 {
            color: #c084fc;
        }

        p {
            color: #b3b3b3;
        }

        hr {
            border-top: 1px solid #2e2447;
        }

        .btn-book-neon {
            background-color: #a855f7;
            border: none;
            color: white;
            font-weight: bold;
            transition: 0.3s ease;
            border-radius: 10px;
        }

            .btn-book-neon:hover {
                background-color: #c084fc;
                box-shadow: 0 0 18px rgba(168, 85, 247, 0.5);
                transform: scale(1.02);
            }

        .actor-img {
            width: 80px;
            height: 80px;
            object-fit: cover;
            border-radius: 50%;
            border: 2px solid #a855f7;
        }
    </style>
</head>

<body>

    <div class="container">
        <div class="card p-4">
            <div class="row">

                <div class="col-md-4 text-center">

                    @if (!string.IsNullOrEmpty(Model.Cinema?.ImageURL))
                    {
                        <img src="@Model.Cinema.ImageURL" class="img-fluid rounded" style="max-height:400px;">
                    }
                    else
                    {
                        <img src="~/images/no-image.jpg" class="img-fluid rounded" style="max-height:400px;">
                    }

                    <div class="mt-3 text-start">
                        <h5>@Model.Cinema?.Name</h5>
                        <p>@Model.Cinema?.Location</p>
                    </div>

                </div>

                <div class="col-md-8">

                    <h2>@Model.Title</h2>
                    <p>@Model.Description</p>

                    <p><strong>Category:</strong> @Model.Category?.Name</p>
                    <p><strong>Price:</strong> @Model.Price $</p>

                    <hr />

                    <h5>Actors</h5>

                    @if (Model.MovieActors != null && Model.MovieActors.Any())
                    {
                        <div class="d-flex flex-wrap gap-3">
                            @foreach (var ma in Model.MovieActors)
                            {
                                <div class="text-center">
                                    <img src="@ma.Actor?.ProfilePicture" class="actor-img" />
                                    <div>@ma.Actor?.Name</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p>No actors</p>
                    }

                    <div class="mt-4">
                        <a asp-action="Index" class="btn btn-secondary">Back</a>
                    </div>

                    <div class="mt-4">
                        <a asp-controller="Orders"
                           asp-action="Book"
                           asp-route-movieId="@Model.Id"
                           class="btn btn-lg btn-book-neon w-100"
                           id="bookBtn">
                            BOOK NOW - @Model.Price.ToString("C")
                        </a>
                    </div>

                </div>

            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            document.getElementById("bookBtn").addEventListener("click", function (e) {
                if (!confirm("Confirm booking this movie?")) {
                    e.preventDefault();
                }
            });
        });
    </script>

</body>
</html>