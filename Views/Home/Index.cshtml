@model IEnumerable<movie_hospital_1.dataModel.Movie>

@{
    ViewData["Title"] = "Movies List";
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

    <style>
        body {
            background-color: #0d0a17;
            color: #f0f0f0;
            font-family: Arial;
        }

        .text-neon {
            color: #d175ff;
            text-shadow: 0 0 8px #d175ff;
            font-weight: bold;
        }

        .navbar-custom {
            background: #1a1625;
            padding: 10px;
            position: relative;
        }

        .dropdown-menu-custom {
            display: none;
            position: absolute;
            right: 20px;
            top: 60px;
            background: #1a1625;
            border: 1px solid #3b3054;
            border-radius: 10px;
            min-width: 180px;
            box-shadow: 0 0 15px rgba(209,117,255,0.4);
            z-index: 999;
        }

            .dropdown-menu-custom.show {
                display: block;
            }

            .dropdown-menu-custom a {
                display: block;
                padding: 10px;
                color: white;
                text-decoration: none;
                border-radius: 6px;
            }

                .dropdown-menu-custom a:hover {
                    background: #6a0dad;
                }

        .card {
            background: #1a1625;
            border: 1px solid #3b3054;
            transition: 0.3s;
        }

            .card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0 20px #d175ff;
            }

        .card-title {
            color: white;
        }

        .btn-info {
            background: #d175ff;
            border: none;
            color: white;
        }

        .btn-book {
            background: #39ff14;
            border: none;
            color: black;
        }
    </style>
</head>

<body>

    <!-- NAVBAR -->
    <div class="navbar-custom d-flex align-items-center justify-content-between">

        <h4 class="text-neon m-0">🎬 Movies App</h4>

        <button class="btn btn-dark" id="menuBtn">Menu ▼</button>

        <div class="dropdown-menu-custom" id="dropdownMenu">
            <a href="/Home/Index">Home</a>
            <a href="/Admin/Dashboard">Dashboard</a>
        </div>

    </div>

    <div class="container mt-4">

        <h2 class="text-center text-neon mb-4">🎬 Movies List</h2>

        <!-- FILTER -->
        <form method="get" asp-action="Index" class="row mb-4">

            <div class="col-md-5">
                <input type="text" name="search" class="form-control"
                       placeholder="Search movies..." value="@ViewBag.Search" />
            </div>

            <div class="col-md-3">
                <select name="categoryId" class="form-select">
                    <option value="">All Categories</option>
                    @foreach (var c in ViewBag.Categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100">Filter</button>
            </div>

        </form>

        <!-- MOVIES -->
        <div class="row">

            @foreach (var movie in Model)
            {
                <div class="col-md-4 mb-4">

                    <div class="card h-100">

                        <img src="@movie.ImageURL" class="card-img-top" style="height:300px; object-fit:cover;" />

                        <div class="card-body">

                            <h5 class="card-title">@movie.Title</h5>

                            <p style="color:white">@movie.Description</p>

                            <p style="color:white"><strong >Price:</strong> @movie.Price</p>

                            <div class="d-flex gap-2">

                                <a asp-action="Details" asp-route-id="@movie.Id"
                                   class="btn btn-info w-50">
                                    Details
                                </a>

                                @if (movie.InCinema)
                                {
                                    <a asp-controller="Orders" asp-action="Book"
                                       asp-route-movieId="@movie.Id"
                                       class="btn btn-book w-50">
                                        Book
                                    </a>
                                }
                                else
                                {
                                    <button class="btn btn-secondary w-50" disabled>Sold Out</button>
                                }

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

    
    <script>
        const menuBtn = document.getElementById("menuBtn");
        const dropdown = document.getElementById("dropdownMenu");

        menuBtn.addEventListener("click", function (e) {
            e.stopPropagation();
            dropdown.classList.toggle("show");
        });

        document.addEventListener("click", function () {
            dropdown.classList.remove("show");
        });
    </script>

</body>
</html>